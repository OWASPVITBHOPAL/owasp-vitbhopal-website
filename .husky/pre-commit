#!/usr/bin/env sh

RED_BG='\033[41m'
GREEN_BG='\033[42m'
BLACK_FG='\033[30m'
WHITE_FG='\033[97m'
RESET='\033[0m'

run_check() {
	label="$1"
	shift
	width=52
	label_length=${#label}
	dots_count=$((width - label_length))
	output_file=$(mktemp)

	if [ "$dots_count" -lt 2 ]; then
		dots_count=2
	fi

	padding=$(printf '%*s' "$dots_count" '' | tr ' ' '.')

	if "$@" >"$output_file" 2>&1; then
		status_label=' PASSED '
		status_style="${GREEN_BG}${BLACK_FG}"
		status_code=0
	else
		status_code=$?
		status_label=' FAILED '
		status_style="${RED_BG}${WHITE_FG}"
	fi

	printf '%s%s%b%s%b\n' "$label" "$padding" "$status_style" "$status_label" "$RESET"
	cat "$output_file"
	rm -f "$output_file"

	if [ "$status_code" -ne 0 ]; then
		exit "$status_code"
	fi
}

run_format_check() {
	width=52
	label='format'
	label_length=${#label}
	dots_count=$((width - label_length))
	output_file=$(mktemp)
	files_file=$(mktemp)

	if [ "$dots_count" -lt 2 ]; then
		dots_count=2
	fi

	padding=$(printf '%*s' "$dots_count" '' | tr ' ' '.')

	git diff --cached --name-only --diff-filter=ACMR | while IFS= read -r file; do
		case "$file" in
			*.js|*.jsx|*.ts|*.tsx|*.mjs|*.cjs|*.json|*.md|*.mdx|*.css|*.scss|*.html|*.yml|*.yaml)
				printf '%s\n' "$file"
				;;
		esac
	done >"$files_file"

	if [ ! -s "$files_file" ]; then
		printf '%s%s%b%s%b\n' "$label" "$padding" "${GREEN_BG}${BLACK_FG}" ' PASSED ' "$RESET"
		rm -f "$output_file" "$files_file"
		return 0
	fi

	status_code=0
	while IFS= read -r file; do
		if [ -z "$file" ]; then
			continue
		fi

		if ./node_modules/.bin/prettier --write "$file" >>"$output_file" 2>&1; then
			git add "$file"
		else
			status_code=$?
			break
		fi
	done <"$files_file"

	if [ "$status_code" -eq 0 ]; then
		status_style="${GREEN_BG}${BLACK_FG}"
		status_label=' PASSED '
	else
		status_style="${RED_BG}${WHITE_FG}"
		status_label=' FAILED '
	fi

	printf '%s%s%b%s%b\n' "$label" "$padding" "$status_style" "$status_label" "$RESET"
	cat "$output_file"
	rm -f "$output_file" "$files_file"

	if [ "$status_code" -ne 0 ]; then
		exit "$status_code"
	fi
}

printf '\n============================================================\n'
printf '                 PRE-COMMIT CHECKS\n'
printf '============================================================\n'

run_format_check
run_check "lint" ./node_modules/.bin/eslint
run_check "typecheck" ./node_modules/.bin/tsc --noEmit
run_check "build" npm run build

printf '\n%b%s%b\n' "${GREEN_BG}${BLACK_FG}" '           ALL CHECKS PASSED           ' "${RESET}"
